# Build output
/target/

# Agent session state notes (operational, not project history)
.agent-state/

# PGO profiling data
/tmp/runbound-pgo/

# Editor temp files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Secrets — never commit
/etc/runbound/api.key
/etc/runbound/key.pem
*.key
*.pem
.env

# Internal reports (French work notes — not for public repo)
AUDIT_SECURITE.txt
RAPPORT_PERFORMANCE.txt
RAPPORT_TEST_COMPLET.txt

# Test artifacts
/tmp/dnsperf-*.out
/tmp/runbound-*.conf
/tmp/queries-*.txt
# Loose local binaries/build artifacts dropped at repo root only — anchored so this
# never shadows docs/benchmark/RUNBOUND-vX.Y.Z-*.md report files (collides on
# case-insensitive filesystems: macOS/Windows treat "runbound-v*" and "RUNBOUND-v*"
# as the same pattern).
/runbound-v*

# Claude Code context — contains local infra credentials, never commit
CLAUDE.md

# Agent state files
.agent-state/
.agent-state/**

# Patch scripts (local tooling)
/tmp/*.py
/tmp/*.sh

# Internal work files
AUDIT_SECURITE.txt
RAPPORT_*.txt
target/
fuzz/target/
